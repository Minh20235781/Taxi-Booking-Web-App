// SQLite — status/type fields use String (no native enums).
// Booking status: REQUESTED | SCHEDULED | CONFIRMED | ASSIGNED | CANCELLED | COMPLETED
// Booking type: INSTANT | SCHEDULED
// Ride status: REQUESTED | ACCEPTED | DRIVER_EN_ROUTE | ARRIVED | IN_PROGRESS | COMPLETED | CANCELLED
// Payment status: PENDING | PROCESSING | PAID | FAILED | REFUNDED
// Message senderRole: USER | DRIVER

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int               @id @default(autoincrement())
  fullName     String
  email        String            @unique
  phone        String
  passwordHash String
  role         String
  address      String?
  city         String?
  country      String?
  avatarUrl    String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  driver       DriverProfile?
  bookings     Booking[]
  riderRides   Ride[]            @relation("rider")
  ratings      Rating[]
  messages     Message[]
  paymentMethods SavedPaymentMethod[]
}

model DriverProfile {
  id                   Int      @id @default(autoincrement())
  userId               Int      @unique
  licenseNumber        String?
  vehiclePlate         String?
  vehicleModel         String?
  vehicleYear          String?
  vehiclePhotoUrl      String?
  vehicleColor         String?
  identificationNumber String?
  languages            String?
  bankName             String?
  accountNumber        String?
  accountHolderName    String?
  isOnline             Boolean  @default(false)
  currentLat           Float?
  currentLng           Float?
  averageRating        Float?
  totalTrips           Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  driverRides          Ride[]   @relation("driver")
  declinedRides        DeclinedRide[]
}

model DeclinedRide {
  id              Int      @id @default(autoincrement())
  bookingId       Int
  driverProfileId Int
  createdAt       DateTime @default(now())

  booking         Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  driver          DriverProfile @relation(fields: [driverProfileId], references: [id], onDelete: Cascade)

  @@unique([bookingId, driverProfileId])
  @@index([bookingId])
  @@index([driverProfileId])
}

model VehicleClass {
  id            Int       @id @default(autoincrement())
  code          String    @unique
  name          String
  baseFare      Float
  pricePerKm    Float
  pricePerMinute Float    @default(0)
  maxCapacity   Int
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  bookings      Booking[]
}

model Booking {
  id                   Int          @id @default(autoincrement())
  userId               Int
  bookingType          String       @default("INSTANT")
  status               String       @default("REQUESTED")
  pickupAddress        String
  destination          String
  pickupPlaceId        String?
  destinationPlaceId   String?
  pickupLat            Float?
  pickupLng            Float?
  destinationLat       Float?
  destinationLng       Float?
  scheduledAt          DateTime?
  routeDistanceMeters  Int?
  routeDurationSeconds Int?
  vehicleClassId       Int
  estimatedFare        Float?
  paymentMethod        String?
  paymentMethodLabel   String?
  preferencesJson      String?
  cancelledAt          DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  user                 User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  vehicleClass         VehicleClass @relation(fields: [vehicleClassId], references: [id], onDelete: Restrict)
  ride                 Ride?
  declinedRides        DeclinedRide[]

  @@index([userId])
  @@index([status])
  @@index([bookingType])
  @@index([scheduledAt])
}

model Ride {
  id                Int            @id @default(autoincrement())
  bookingId         Int            @unique
  riderId           Int
  driverProfileId   Int?
  status            String         @default("REQUESTED")
  acceptedAt        DateTime?
  driverEnRouteAt   DateTime?
  arrivedAt         DateTime?
  startedAt         DateTime?
  endTime           DateTime?
  cancelledAt       DateTime?
  cancelReason      String?
  finalFare         Float?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  booking           Booking        @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  rider             User           @relation("rider", fields: [riderId], references: [id], onDelete: Restrict)
  driver            DriverProfile? @relation("driver", fields: [driverProfileId], references: [id], onDelete: SetNull)
  payment           Payment?
  rating            Rating?
  messages          Message[]

  @@index([status])
  @@index([driverProfileId])
  @@index([riderId])
}

model Payment {
  id                Int       @id @default(autoincrement())
  rideId            Int       @unique
  method            String
  provider          String?
  externalId        String?   @unique
  amount            Float
  currency          String    @default("VND")
  status            String    @default("PENDING")
  failureReason     String?
  paidAt            DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  ride              Ride      @relation(fields: [rideId], references: [id], onDelete: Restrict)

  @@index([status])
}

model SavedPaymentMethod {
  id         Int      @id @default(autoincrement())
  userId     Int
  type       String
  label      String
  last4      String?
  provider   String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Message {
  id             Int      @id @default(autoincrement())
  rideId         Int
  senderUserId   Int
  senderRole     String
  body           String
  translatedBody String?
  createdAt      DateTime @default(now())
  ride           Ride     @relation(fields: [rideId], references: [id], onDelete: Cascade)
  sender         User     @relation(fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([rideId])
  @@index([createdAt])
}

model Rating {
  id         Int      @id @default(autoincrement())
  rideId     Int      @unique
  userId     Int
  score      Int
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  ride       Ride     @relation(fields: [rideId], references: [id], onDelete: Restrict)
  user       User     @relation(fields: [userId], references: [id], onDelete: Restrict)
}
