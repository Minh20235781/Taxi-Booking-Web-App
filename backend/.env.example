# Pooler — app runtime (Supabase transaction mode, port 6543)
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct — migrations only (session mode, port 5432)
DIRECT_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

PORT=4000
JWT_SECRET="replace_with_strong_secret_min_32_chars"

# Comma-separated frontend URLs for CORS (Vercel domain + localhost for dev)
FRONTEND_URL="https://your-app.vercel.app,http://localhost:5173"

PHOTON_BASE_URL="https://photon.komoot.io/api"
NOMINATIM_BASE_URL="https://nominatim.openstreetmap.org/search"
NOMINATIM_USER_AGENT="taxi-booking-app/1.0"
OSRM_BASE_URL="https://router.project-osrm.org"
HANOI_BBOX="105.73,20.95,106.02,21.25"
GOOGLE_TRANSLATE_API_KEY=""
